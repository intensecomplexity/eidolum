{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://eidolum-production.up.railway.app/sitemap.xml" },
    { "source": "/robots.txt", "destination": "https://eidolum-production.up.railway.app/robots.txt" },
    { "source": "/api/og-image/:path*", "destination": "https://eidolum-production.up.railway.app/api/og-image/:path*" },
    { "source": "/api/logo/:path*", "destination": "https://eidolum-production.up.railway.app/api/logo/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
